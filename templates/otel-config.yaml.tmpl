extensions:
  health_check:
    endpoint: "0.0.0.0:13133"
%{ if enable_logs ~}
  # Required since 0.132.0: enables decoding Cloud Logging entries from Pub/Sub.
  google_cloud_logentry_encoding: {}
%{ endif ~}

receivers:
%{ if enable_logs ~}
  googlecloudpubsub:
    project: ${project_id}
    subscription: ${subscription}
    encoding: google_cloud_logentry_encoding
    ignore_encoding_error: true
%{ endif ~}
%{ if enable_metrics ~}
  googlecloudmonitoring:
    project_id: ${project_id}
    collection_interval: ${collection_interval}
    metrics_list:
      # Compute
      - metric_descriptor_filter: 'metric.type = starts_with("compute.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("container.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("autoscaler.googleapis.com/")'
      # Serverless Compute
      - metric_descriptor_filter: 'metric.type = starts_with("run.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("cloudfunctions.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("appengine.googleapis.com/")'
      # Messaging
      - metric_descriptor_filter: 'metric.type = starts_with("pubsub.googleapis.com/")'
      # Data Warehouse & Analytics
      - metric_descriptor_filter: 'metric.type = starts_with("bigquery.googleapis.com/")'
      # Databases
      - metric_descriptor_filter: 'metric.type = starts_with("cloudsql.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("redis.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("bigtable.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("firestore.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("spanner.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("alloydb.googleapis.com/")'
      # Storage
      - metric_descriptor_filter: 'metric.type = starts_with("storage.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("filestore.googleapis.com/")'
      # Networking
      - metric_descriptor_filter: 'metric.type = starts_with("loadbalancing.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("networkservices.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("networksecurity.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("dns.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("vpn.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("router.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("interconnect.googleapis.com/")'
      # AI / ML
      - metric_descriptor_filter: 'metric.type = starts_with("aiplatform.googleapis.com/")'
      # Orchestration
      - metric_descriptor_filter: 'metric.type = starts_with("composer.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("cloudtasks.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("cloudscheduler.googleapis.com/")'
      # Firebase
      - metric_descriptor_filter: 'metric.type = starts_with("firebaseappcheck.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("firebasedatabase.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("firebasehosting.googleapis.com/")'
      # Custom & User-defined Metrics
      - metric_descriptor_filter: 'metric.type = starts_with("custom.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("external.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("logging.googleapis.com/user/")'
      # GKE / Kubernetes
      - metric_descriptor_filter: 'metric.type = starts_with("kubernetes.io/")'
      # CI/CD & Artifact Management
      - metric_descriptor_filter: 'metric.type = starts_with("cloudbuild.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("artifactregistry.googleapis.com/")'
      # Data Processing
      - metric_descriptor_filter: 'metric.type = starts_with("dataflow.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("dataproc.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("datastream.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("bigquerystorage.googleapis.com/")'
      # Additional Storage & Databases
      - metric_descriptor_filter: 'metric.type = starts_with("memcache.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("datastore.googleapis.com/")'
      # Serverless & Orchestration
      - metric_descriptor_filter: 'metric.type = starts_with("workflows.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("eventarc.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("batch.googleapis.com/")'
      # Security & Identity
      - metric_descriptor_filter: 'metric.type = starts_with("secretmanager.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("certificatemanager.googleapis.com/")'
      # Platform & Quota
      - metric_descriptor_filter: 'metric.type = starts_with("serviceruntime.googleapis.com/")'
      - metric_descriptor_filter: 'metric.type = starts_with("monitoring.googleapis.com/")'
      # TPU / Accelerators
      - metric_descriptor_filter: 'metric.type = starts_with("tpu.googleapis.com/")'
%{ endif ~}

processors:
  resourcedetection:
    detectors: [env, gcp]
  batch:
    timeout: 5s

exporters:
  otlphttp:
    endpoint: ${tsuga_intake_url}
    headers:
      Authorization: Bearer $${env:TSUGA_API_KEY}
    compression: gzip
    timeout: 30s
    retry_on_failure:
      enabled: true
      initial_interval: 1s
      max_interval: 10s
      max_elapsed_time: 10s
    sending_queue:
      enabled: true
      num_consumers: 4
      queue_size: 4096

service:
  extensions: [health_check%{ if enable_logs ~}, google_cloud_logentry_encoding%{ endif ~}]
  pipelines:
%{ if enable_logs ~}
    logs:
      receivers: [googlecloudpubsub]
      processors: [resourcedetection, batch]
      exporters: [otlphttp]
%{ endif ~}
%{ if enable_metrics ~}
    metrics:
      receivers: [googlecloudmonitoring]
      processors: [resourcedetection, batch]
      exporters: [otlphttp]
%{ endif ~}
  telemetry:
    logs:
      level: debug
      encoding: json
      processors:
        - batch:
            exporter:
              otlp:
                protocol: http/protobuf
                headers:
                  Authorization: Bearer $${env:TSUGA_API_KEY}
                endpoint: ${tsuga_intake_url}/v1/logs
    metrics:
      readers:
        - periodic:
            exporter:
              otlp:
                protocol: http/protobuf
                headers:
                  Authorization: Bearer $${env:TSUGA_API_KEY}
                endpoint: ${tsuga_intake_url}/v1/metrics
    traces:
      processors:
        - batch:
            exporter:
              otlp:
                protocol: http/protobuf
                headers:
                  Authorization: Bearer $${env:TSUGA_API_KEY}
                endpoint: ${tsuga_intake_url}/v1/traces
